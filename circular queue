#include <stdio.h>
#define SIZE 4

int queue[SIZE];
int front = -1, rear = -1;

// ENQUEUE
void enqueue(int value) {
    if ((rear + 1) % SIZE == front) {
        printf("Queue Full\n");
    } else {
        if (front == -1) {
            front = rear = 0;
        } else {
            rear = (rear + 1) % SIZE;
        }
        queue[rear] = value;
        printf("%d added\n", value);
    }
}

// DEQUEUE
void dequeue() {
    if (front == -1) {
        printf("Queue Empty\n");
    } else {
        printf("%d removed\n", queue[front]);

        if (front == rear) {
            front = rear = -1; // reset
        } else {
            front = (front + 1) % SIZE;
        }
    }
}

// DISPLAY
void display() {
    if (front == -1) {
        printf("Queue Empty\n");
    } else {
        int i = front;
        while (1) {
            printf("%d ", queue[i]);
            if (i == rear) break;
            i = (i + 1) % SIZE;
        }
        printf("\n");
    }
}

// MAIN
int main() {
    enqueue(1);
    enqueue(2);
    enqueue(3);
    enqueue(4);
    dequeue();
    enqueue(5);
    display();
    return 0;
}
