#include <stdio.h>
#define MAX 5

int queue[MAX];
int front = -1, rear = -1;

// ENQUEUE FUNCTION
void enqueue(int value) {
    if (rear == MAX - 1) {
        printf("Queue Overflow\n");
    } else {
        if (front == -1) front = 0;
        rear++;
        queue[rear] = value;
        printf("%d added\n", value);
    }
}

// DEQUEUE FUNCTION
void dequeue() {
    if (front == -1 || front > rear) {
        printf("Queue Underflow\n");
    } else {
        printf("%d removed\n", queue[front]);
        front++;
    }
}

// DISPLAY FUNCTION
void display() {
    if (front == -1 || front > rear) {
        printf("Queue is Empty\n");
    } else {
        for (int i = front; i <= rear; i++) {
            printf("%d ", queue[i]);
        }
        printf("\n");
    }
}

// MAIN FUNCTION
int main() {
    enqueue(10);
    enqueue(20);
    dequeue();
    display();
    return 0;
}
