//linked-list using function first create newnode function and then display and then first operation insertion at beginning.
//
#include<stdio.h>
#include<stdlib.h>
struct node {
    int data;
    struct node* next;
};


struct node* createNode(int value) {
    struct node* newNode = (struct node*)malloc(sizeof(struct node));
    
    newNode->data = value;
    newNode->next = NULL;
    
    return newNode;
}
// display function
void display(struct node* head) {
    
    struct node* temp = head;
    
    while (temp != NULL) {
        printf("%d -> ", temp->data);
        temp = temp->next;
    }
    
    printf("NULL\n");
}
// insertion at beginning
struct node* ib(struct node* head,int value){
    
    struct node* newnode= createNode(value);
    
    newnode->next=head;
    return newnode;
    
}
//adding new function endlist() to insert element in the last of the linked list

struct node* endlist(struct node* head,int value){
    struct node* newnode = createNode(value);
   
        struct node*  temp=head;
        while(temp->next != NULL){
            
            temp= temp-> next;
            temp->next=newnode;
        
    
         return head;}
    
}
// sdding new operation insertion at given pos.
struct node* pos(struct node*head , int value , int pos){
    if(pos < 0){
        printf("\n  invalid pos ");
        return head;
    }
    struct node* newnode = createNode(value);
    if(pos  == 1){
        newnode->next = head;
        return newnode;
    }
    
    struct node* temp= head;
    int i;
    for(i=1;i<pos-1 && temp != NULL ; i++){
        
        temp = temp->next;
        if(temp == NULL){
            
            printf("\n postion not available");
        }
        return head;
    }
    newnode->next=temp->next;
    temp->next =  newnode;
    return head;
}

