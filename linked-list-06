//linked-list using function first create newnode function and then display and then first operation insertion at beginning.
//
#include<stdio.h>
#include<stdlib.h>
struct node {
    int data;
    struct node* next;
};


struct node* createNode(int value) {
    struct node* newNode = (struct node*)malloc(sizeof(struct node));
    
    newNode->data = value;
    newNode->next = NULL;
    
    return newNode;
}
// display function
void display(struct node* head) {
    
    struct node* temp = head;
    
    while (temp != NULL) {
        printf("%d -> ", temp->data);
        temp = temp->next;
    }
    
    printf("NULL\n");
}
// nsertion at beginning
struct node* ib(struct node* head,int value){
    
    struct node* newnode= createNode(value);
    
    newnode->next=head;
    return newnode;
    
}

int main(){
    struct node* head=NULL;
head=ib(head,10);
    head=ib(head,20);
    display(head);
    return 0;
    
}
